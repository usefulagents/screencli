{
  "name": "screencli",
  "version": "0.3.0",
  "description": "AI-powered screen recording CLI tool",
  "type": "module",
  "bin": {
    "screencli": "dist/bin/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.tui.json",
    "dev": "tsx bin/cli.ts",
    "start": "node dist/bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write '**/*.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "open": "^11.0.0",
    "ora": "^8.2.0",
    "playwright": "^1.50.0",
    "react": "^18.3.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.28",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "screen-recording",
    "ai-agent",
    "browser-recording",
    "cli",
    "playwright",
    "claude",
    "demo",
    "screencast",
    "video"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usefulagents/screencli.git"
  },
  "homepage": "https://screencli.sh"
}
